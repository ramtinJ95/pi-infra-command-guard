{
  "name": "@ramtinj95/pi-infra-command-guard",
  "version": "0.4.0",
  "description": "Approval guard for risky infrastructure, cloud, and local file commands in Pi and GPT-5.6 Code Mode",
  "type": "module",
  "license": "MIT",
  "author": "Ramtin Javanmardi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ramtinJ95/pi-infra-command-guard.git"
  },
  "homepage": "https://github.com/ramtinJ95/pi-infra-command-guard#readme",
  "bugs": {
    "url": "https://github.com/ramtinJ95/pi-infra-command-guard/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "infrastructure",
    "kubectl",
    "terraform",
    "helm",
    "argocd",
    "aws",
    "azure",
    "gcloud",
    "approval"
  ],
  "files": [
    "extensions/infra-command-guard/index.ts",
    "extensions/infra-command-guard/approval-ui.ts",
    "extensions/infra-command-guard/approvals.ts",
    "extensions/infra-command-guard/attention.ts",
    "extensions/infra-command-guard/code-mode.ts",
    "extensions/infra-command-guard/guarded-executables.ts",
    "extensions/infra-command-guard/policy.ts",
    "extensions/infra-command-guard/shell.ts",
    "extensions/infra-command-guard/tool-policies.ts",
    "AGENTS.md",
    "infra-command-guard.schema.json",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "pi": {
    "extensions": [
      "./extensions/infra-command-guard/index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.81.1",
    "@earendil-works/pi-tui": "^0.81.1",
    "@types/node": "^24.0.0",
    "typebox": "^1.1.38",
    "typescript": "^7.0.2"
  },
  "scripts": {
    "benchmark:policy": "bun extensions/infra-command-guard/policy.bench.ts",
    "test": "bun extensions/infra-command-guard/index.test.ts",
    "typecheck": "tsc",
    "test:package": "npm pack --dry-run",
    "check": "npm run typecheck && npm test && npm run test:package"
  },
  "publishConfig": {
    "access": "public"
